# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Groq  → https://console.groq.com/  (free tier: ~14,400 RPD / 30 RPM)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Together AI → https://api.together.xyz/ (free tier: $5 credit)
TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Model Selection ────────────────────────────────────────────────────────────
# Architect + Resolver use the large reasoning model
ARCHITECT_MODEL=llama-3.3-70b-versatile        # Groq model name
RESOLVER_MODEL=llama-3.3-70b-versatile

# Extractor uses the fast/cheap model
EXTRACTOR_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct   # Together model name

# ── FalkorDB ──────────────────────────────────────────────────────────────────
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH_NAME=knowledge_graph

# ── Pipeline Tuning ───────────────────────────────────────────────────────────
# Max retry attempts on 429 / 503 errors
MAX_RETRIES=6
# Max tokens per Extractor call (keep low to fit free context windows)
MAX_CHUNK_TOKENS=2048
